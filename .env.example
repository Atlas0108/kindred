# Copy to `.env` in the project root (already listed in pubspec assets) and set values.
# Same keys as `.env`; this file is documentation only.

# Optional: Firebase Admin scripts (seed_demo, delete_all_posts). If unset, they use
# secrets/firebase-adminsdk.json when that file exists (gitignored — copy your service account there).
# GOOGLE_APPLICATION_CREDENTIALS=

KINDRED_DEV_EMAIL=
KINDRED_DEV_PASSWORD=

# Optional: prefill compose / new-event fields in dev (same pattern as KINDRED_DEV_EMAIL).
KINDRED_DEV_HELP_OFFER_TITLE= 'I can help you with your taxes'
KINDRED_DEV_HELP_OFFER_BODY= 'I am a tax professional and I can help you with your taxes.'
KINDRED_DEV_HELP_REQUEST_TITLE= 'I need help with my taxes'
KINDRED_DEV_HELP_REQUEST_BODY= 'I am a tax professional and I can help you with your taxes.'
KINDRED_DEV_EVENT_TITLE= 'I am organizing a tax workshop'
KINDRED_DEV_EVENT_ORGANIZER= 'I am a tax professional and I can help you with your taxes.'
KINDRED_DEV_EVENT_DESCRIPTION= 'I am a tax professional and I can help you with your taxes.'

# Home area search uses Photon (komoot.io, OSM data) from the client — no API key.
