rules_version = '2';
// Chat: strict access on conversations + messages. Other paths still use the
// permissive rule at the bottom until you lock down users/posts/events.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Must match [UserProfileService.normalizeStaffEmail] (trim + lowercase on write).
    function authEmailString() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : '';
    }

    function staffListedOnUserDoc(participantUserId) {
      return signedIn()
        && participantUserId is string
        && exists(/databases/$(database)/documents/users/$(participantUserId))
        && get(/databases/$(database)/documents/users/$(participantUserId)).data.keys().hasAny(['staffEmails'])
        && get(/databases/$(database)/documents/users/$(participantUserId)).data.staffEmails is list
        && authEmailString() != ''
        && authEmailString() in get(/databases/$(database)/documents/users/$(participantUserId)).data.staffEmails;
    }

    match /conversations/{convId} {

      function convPath() {
        return /databases/$(database)/documents/conversations/$(convId);
      }

      function conversationExists() {
        return exists(convPath());
      }

      function isConversationParticipant() {
        return signedIn()
          && conversationExists()
          && resource.data.participantIds is list
          && resource.data.participantIds.size() == 2
          && uid() in resource.data.participantIds;
      }

      function canAccessConversationDoc() {
        return signedIn()
          && resource.data.participantIds is list
          && resource.data.participantIds.size() == 2
          && (
            uid() in resource.data.participantIds
            || staffListedOnUserDoc(resource.data.participantIds[0])
            || staffListedOnUserDoc(resource.data.participantIds[1])
          );
      }

      function willBeConversationParticipant() {
        return signedIn()
          && request.resource.data.participantIds is list
          && request.resource.data.participantIds.size() == 2
          && uid() in request.resource.data.participantIds
          && request.resource.data.participantIds[0] is string
          && request.resource.data.participantIds[1] is string
          && request.resource.data.participantIds[0] != request.resource.data.participantIds[1];
      }

      function willBeStaffDelegateConversation() {
        return signedIn()
          && request.resource.data.participantIds is list
          && request.resource.data.participantIds.size() == 2
          && request.resource.data.participantIds[0] is string
          && request.resource.data.participantIds[1] is string
          && request.resource.data.participantIds[0] != request.resource.data.participantIds[1]
          && (
            staffListedOnUserDoc(request.resource.data.participantIds[0])
            || staffListedOnUserDoc(request.resource.data.participantIds[1])
          );
      }

      function participantIdsUnchanged() {
        return request.resource.data.participantIds == resource.data.participantIds;
      }

      // Allow listening before the doc exists (client creates right after); otherwise members or org staff.
      allow read: if signedIn()
        && (
          !conversationExists()
          || canAccessConversationDoc()
        );

      allow create: if (
          willBeConversationParticipant()
          && request.resource.data.keys().hasAll([
            'participantIds',
            'participantNames',
            'lastMessageText',
            'lastMessageAt',
            'updatedAt',
            'createdAt',
          ])
        )
        || (
          willBeStaffDelegateConversation()
          && request.resource.data.keys().hasAll([
            'participantIds',
            'participantNames',
            'lastMessageText',
            'lastMessageAt',
            'updatedAt',
            'createdAt',
          ])
        );

      allow update: if signedIn()
        && participantIdsUnchanged()
        && canAccessConversationDoc();

      allow delete: if false;

      match /messages/{msgId} {

        function convParticipants() {
          return get(convPath()).data.participantIds;
        }

        function canAccessConversationMessages() {
          return signedIn()
            && conversationExists()
            && convParticipants() is list
            && convParticipants().size() == 2
            && (
              uid() in convParticipants()
              || staffListedOnUserDoc(convParticipants()[0])
              || staffListedOnUserDoc(convParticipants()[1])
            );
        }

        allow read: if canAccessConversationMessages();

        allow create: if signedIn()
          && conversationExists()
          && convParticipants() is list
          && convParticipants().size() == 2
          && request.resource.data.keys().hasAll(['senderId', 'text', 'createdAt'])
          && request.resource.data.senderId in convParticipants()
          && (
            request.resource.data.senderId == uid()
            || staffListedOnUserDoc(request.resource.data.senderId)
          )
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 8000;

        allow update, delete: if false;
      }
    }

    match /users/{userId}/savedPosts/{postId} {
      allow read: if signedIn() && uid() == userId;
      allow create: if signedIn()
        && uid() == userId
        && request.resource.data.postId == postId
        && request.resource.data.keys().hasAll(['postId', 'savedAt']);
      allow delete: if signedIn() && uid() == userId;
      allow update: if false;
    }

    // TEMPORARY: rest of the app (users, posts, events, etc.)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
