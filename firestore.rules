rules_version = '2';
// TEMPORARY TEST RULES: any signed-in user can read/write the entire database.
// Revert to the previous rules (git checkout firestore.rules) before any real users or production.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
