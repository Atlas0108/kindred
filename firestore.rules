rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['displayName', 'discoveryRadiusMiles', 'karma']);
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.keys().hasAll([
            'authorId', 'authorName', 'kind', 'tags', 'title', 'geoPoint', 'geohash', 'status', 'createdAt'
          ]);
      allow update: if request.auth != null
          && resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null
          && resource.data.authorId == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if request.auth != null
          && request.resource.data.organizerId == request.auth.uid
          && request.resource.data.keys().hasAll([
            'organizerId', 'title', 'description', 'startsAt', 'endsAt',
            'organizerName', 'tags', 'locationDescription',
            'geoPoint', 'geohash', 'createdAt'
          ]);
      allow update: if request.auth != null
          && resource.data.organizerId == request.auth.uid;
      allow delete: if request.auth != null
          && resource.data.organizerId == request.auth.uid;

      match /rsvps/{rsvpUserId} {
        allow read: if true;
        allow create, update: if request.auth != null
            && request.auth.uid == rsvpUserId
            && request.resource.data.userId == rsvpUserId;
        allow delete: if request.auth != null && request.auth.uid == rsvpUserId;
      }
    }
  }
}
